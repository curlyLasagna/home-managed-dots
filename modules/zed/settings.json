// Zed settings
//
// For information on how to configure Zed, see the Zed documentation:
// https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your custom settings,
// run the `open default settings` command from the command palette or from `Zed` application menu.
{
  // =========================
  // UI & Appearance
  // =========================
  "preview_tabs": {
    "enabled": true
  },
  "show_whitespaces": "trailing",
  "inlay_hints": {
    "enabled": true
  },
  "icon_theme": "Catppuccin Latte",
  "theme": "Catppuccin Mocha",
  "indent_guides": {
    "enabled": true,
    "coloring": "indent_aware"
  },
  "soft_wrap": "editor_width",
  "scrollbar": {
    "show": "auto"
  },
  // Disabled cursor blink to reduce visual lag
  "cursor_blink": false,
  "relative_line_numbers": "enabled",
  // =========================
  // Font Settings
  // =========================
  "ui_font_size": 15,
  "ui_font_family": ".ZedSans",
  "buffer_font_family": "RobotoMono Nerd Font Mono",
  "buffer_font_size": 13.0,
  "buffer_font_features": {
    "liga": true
  },
  // =========================
  // Editor Behavior
  // =========================
  "format_on_save": "on",
  "formatter": "language_server",
  // =========================
  // Vim Mode
  // =========================
  "vim_mode": false,
  "vim": {
    // "always": use system clipboard when no register is specified
    // "never": don't use system clipboard unless "+ or "* is specified
    // "on_yank": use system clipboard for yank operations when no register is specified
    "use_system_clipboard": "always",
    "toggle_relative_line_numbers": true
  },
  // =========================
  // Panels & Docking
  // =========================
  "git_panel": {
    "dock": "left"
  },
  "project_panel": {
    "dock": "right"
  },
  // Git settings
  "git": {
    "inline_blame": {
      "delay_ms": 5000
    }
  },
  // =========================
  // Tabs & Tab Bar
  // =========================
  // Only show error on tab
  "tabs": {
    "file_icons": true,
    "git_status": true,
    "show_diagnostics": "errors"
  },
  // Hide tabs
  "tab_bar": {
    "show_nav_history_buttons": false,
    "show": true
  },
  // =========================
  // Terminal
  // =========================
  "terminal": {
    "shell": {
      "program": "fish"
    },
    "font_family": "ZedMono Nerd Font Mono",
    "font_size": 13,
    "option_as_meta": true,
    "working_directory": "current_project_directory"
  },
  // =========================
  // Language-specific Settings
  // =========================
  "languages": {
    "Python": {
      "formatter": {
        "language_server": {
          "name": "ruff"
        }
      },
      "language_servers": [
        "pyright",
        "ruff"
      ]
    },
    "Nix": {
      "language_servers": [
        "nil"
      ]
    }
  },
  // =========================
  // LSP (Language Server Protocol) Settings
  // =========================
  "lsp": {
    "pyright": {
      "settings": {
        "pyright.analysis": {
          "diagnosticMode": "workspace",
          "typeCheckingMode": "off"
        }
      }
    },
    "tinymist": {
      "settings": {
        "exportPdf": "onSave",
        "outputPath": "$root/$name"
      }
    }
  },
  // =========================
  // Edit Prediction & Features
  // =========================
  "edit_predictions": {
    "provider": "none",
    "mode": "subtle"
  },
  // =========================
  // Agent & AI Assistant
  // =========================
  "agent": {
    "default_profile": "ask",
    "profiles": {
      "edit": {
        "name": "Edit",
        "tools": {
          "diagnostics": true,
          "read_file": true,
          "create_directory": false,
          "edit_file": true
        },
        "enable_all_context_servers": false,
        "context_servers": {}
      }
    },
    "single_file_review": true,
    "default_model": {
      "provider": "copilot_chat",
      "model": "gpt-4.1"
    },
    "dock": "left"
  },
  // =========================
  // Telemetry & Privacy
  // =========================
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  // =========================
  // File & Project Exclusions
  // =========================
  "file_scan_exclusions": [
    "**/.git",
    "**/.svn",
    "**/.hg",
    "**/CVS",
    "**/.DS_Store",
    "**/Thumbs.db",
    "**/.classpath",
    "**/.settings",
    // above is default from Zed
    "**/out",
    "**/dist",
    "**/.husky",
    "**/.turbo",
    "**/.vscode-test",
    "**/.vscode",
    "**/.next",
    "**/.storybook",
    "**/.tap",
    "**/.nyc_output",
    "**/report",
    "**/node_modules"
  ]
}
