[
  {
    // ============================
    // Normal Mode Key Bindings
    // ============================
    "context": "Editor && vim_mode == normal && vim_operator == none && !VimWaiting",
    "bindings": {
      // File Operations
      // --------------
      "space f s": "workspace::Save",
      "space f f": "file_finder::Toggle",
      // Pane Management
      // --------------
      // Zen mode
      "space t z": "workspace::ToggleCenteredLayout",
      // Splitting
      "space w s": "pane::SplitHorizontal",
      "space w v": "pane::SplitVertical",
      "space b d": "pane::CloseActiveItem",
      "space w d": [
        "pane::CloseCleanItems",
        {
          "close_pinned": false
        }
      ],
      // Navigation between panes
      "space w l": "workspace::ActivatePaneRight",
      "space w h": "workspace::ActivatePaneLeft",
      "space w j": "workspace::ActivatePaneDown",
      "space w k": "workspace::ActivatePaneUp",
      // Tab Navigation
      "tab": "pane::ActivateNextItem",
      "shift-tab": "pane::ActivatePreviousItem",
      // LSP Features
      // -----------
      // Code Actions
      "space c a": "editor::ToggleCodeActions",
      "space .": "editor::ToggleCodeActions",
      "space c r": "editor::Rename",
      "space s l": "vim::PushToggleComments",
      // Code Navigation
      "g d": "editor::GoToDefinition",
      "g D": "editor::GoToDefinitionSplit",
      "g i": "editor::GoToImplementation",
      "g I": "editor::GoToImplementationSplit",
      "g t": "editor::GoToTypeDefinition",
      "g T": "editor::GoToTypeDefinitionSplit",
      "g r": "editor::FindAllReferences",
      // TODO: Go to next/prev error (currently same as diagnostic)
      "] e": "editor::GoToDiagnostic",
      "[ e": "editor::GoToPreviousDiagnostic",
      // Diagnostics
      "space x x": "diagnostics::Deploy"
    }
  },
  {
    // ============================
    // Vim Control Mode
    // ============================
    "context": "VimControl && !menu && vim_mode != operator",
    "bindings": {
      // Word Navigation
      "w": "vim::NextSubwordStart",
      "b": "vim::PreviousSubwordStart",
      "g e": "vim::PreviousSubwordEnd"
    }
  },
  {
    // ============================
    // Vim Normal Mode Specific
    // ============================
    "context": "vim_mode == normal",
    "bindings": {
      // Sneak Navigation
      "s": "vim::PushSneak"
    }
  },
  {
    // ============================
    // Vim Visual Mode
    // ============================
    "context": "Editor && vim_mode == visual && !VimWaiting && !VimObject",
    "bindings": {
      // Vim Surround
      "shift-s": "vim::PushAddSurrounds"
    }
  },
  {
    // ============================
    // Global Bindings
    // ============================
    "bindings": {
      // Buffer/Tab Management
      "space b b": "tab_switcher::ToggleAll"
    }
  }
]
